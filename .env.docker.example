# Copy this file to .env.docker and update secure values before running docker compose.

# PostgreSQL
POSTGRES_USER=veripaper
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=veripaper
POSTGRES_PORT=5432

# Backend
ENVIRONMENT=production
LOG_LEVEL=INFO
PROJECT_NAME=VeriPaper API
APP_VERSION=1.0.0
BACKEND_PORT=8000
MAX_UPLOAD_SIZE_MB=15
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8000/api

# Nginx ingress
NGINX_PORT=80
NGINX_HTTPS_PORT=443
NGINX_CONF_FILE=./deploy/nginx/default.conf

# TLS (used with docker-compose.tls.yml)
TLS_CERT_PATH=./deploy/certs/fullchain.pem
TLS_KEY_PATH=./deploy/certs/privkey.pem
DOMAIN_NAME=localhost
